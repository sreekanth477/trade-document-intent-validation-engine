# ============================================================
# Trade Document Intent Validation Engine - Backend Environment
# ============================================================
# Copy this file to .env and fill in all values before starting.

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database ---
# Full PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/trade_doc_validation

# --- Redis ---
# Full Redis connection string (used by Bull queue)
REDIS_URL=redis://localhost:6379

# --- Anthropic / LLM ---
# API key for Anthropic Claude (used when USE_MOCK_LLM=false)
ANTHROPIC_API_KEY=sk-ant-...
# Set to "true" to use a mock LLM response instead of calling Anthropic API.
# Use this to comply with on-premise data policies during testing.
USE_MOCK_LLM=false

# --- Authentication ---
# Strong random string used to sign JWTs (min 64 chars recommended)
JWT_SECRET=change_me_to_a_very_long_random_secret_string_at_least_64_chars
# JWT token expiry duration (e.g. "8h", "1d")
JWT_EXPIRY=8h

# --- File Upload ---
# Absolute path to the directory where uploaded documents are stored
UPLOAD_DIR=/var/data/trade-doc-uploads
# Maximum single file size in bytes (default: 50 MB)
MAX_FILE_SIZE=52428800
# Maximum number of files per upload request
MAX_FILES_PER_REQUEST=20

# --- Logging ---
# Log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
# Directory for log files (created automatically if absent)
LOG_DIR=./logs

# --- CORS ---
# Comma-separated list of allowed origins, or * for all (not recommended in prod)
CORS_ORIGIN=http://localhost:3000

# --- Rate Limiting ---
# Maximum requests per IP per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
